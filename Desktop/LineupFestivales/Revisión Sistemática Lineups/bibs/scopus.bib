@ARTICLE{Wang2023,
	author = {Wang, Zufeng and Luo, Chengliang and Zhou, Edward W. and Sandhu, Aaron F. and Yuan, Xiaojing and Williams, George E. and Cheng, Jialu and Sinha, Bharati and Akbar, Mohammed and Bhattacharya, Pallab and Zhou, Shuanhu and Song, Byoung-Joon and Wang, Xin},
