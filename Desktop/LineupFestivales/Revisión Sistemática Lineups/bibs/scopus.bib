@ARTICLE{Hayes202181,
	author = {Hayes, Jameson L. and Britt, Brian C. and Evans, William and Rush, Stephen W. and Towery, Nathan A. and Adamson, Alyssa C.},
	title = {Can Social Media Listening Platforms’ Artificial Intelligence Be Trusted? Examining the Accuracy of Crimson Hexagon’s (Now Brandwatch Consumer Research’s) AI-Driven Analyses},
