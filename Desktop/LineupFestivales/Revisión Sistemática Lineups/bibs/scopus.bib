}

@ARTICLE{Ahmed20243483,
	author = {Ahmed, Salahuddin and Singh, Sapna and Samala, Nagaraj},
	title = {What do online reviews communicate? An evidence from emerging economy},
	year = {2024},
	journal = {International Journal of Emerging Markets},
	volume = {19},
