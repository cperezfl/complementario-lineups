	keywords = {Alcohol Drinking; Alcoholism; Brain Injuries, Traumatic; Comorbidity; Humans; Stress Disorders, Post-Traumatic; alcohol; cytokine; alcoholism; comorbidity; epigenetics; genetic analysis; human; inflammation; metabolic disorder; metabolomics; neuroendocrine system; pathophysiology; posttraumatic stress disorder; Review; signal transduction; toxicology; traumatic brain injury; alcoholism; complication; drinking behavior; metabolism; posttraumatic stress disorder; traumatic brain injury},
	type = {Review},
