@ARTICLE{Leiras20242584,
	author = {Leiras, Ana and Eusébio, Celeste},
	title = {Perceived image of accessible tourism destinations: a data mining analysis of Google Maps reviews},
	year = {2024},
	journal = {Current Issues in Tourism},
	volume = {27},
	number = {16},
	pages = {2584 - 2602},
	doi = {10.1080/13683500.2023.2230338},
	url = {https://www.scopus.com/pages/publications/85164569361?origin=resultslist},
	abstract = {While research into tourism and accessibility has significantly advanced over the past decade, the perceived image of Accessible Tourism Destinations (ATDs) has remained largely unexplored. This study addresses this gap by examining the perceived image of Aveiro (Portugal) and A Coruña (Spain) as exemplars of ATDs. In this investigation, we scrutinized 1,051 Online Travellers Reviews (OTRs) posted between 2016 to 2023 in Google Maps. We employed content analysis and text mining techniques using the RapidMiner software. The findings reveal a correlation between accessibility conditions and visitors’ satisfaction. Common concerns among travellers include the availability of parking spaces and adaptations for people with disabilities (PwD). Areas identified for improvement encompass information provision and signage. Further investigation is recommended to understand the factors influencing the increase in positive sentiments in Aveiro during the COVID-19 pandemic. This research presents a strategic framework for Destination Management Organisations (DMOs) to enhance the quality of the tourism offer while showcasing the potential of data mining within this field. © 2023 Informa UK Limited, trading as Taylor & Francis Group.},
	author_keywords = {Accessible Tourism (AT); big data; data mining; destination management; Disability; inclusive tourism; marketing; sentiment analysis; sustainable tourism; tourism; tourism management},
	keywords = {Spain; accessibility; COVID-19; data mining; tourism management; tourism market; tourist destination},
