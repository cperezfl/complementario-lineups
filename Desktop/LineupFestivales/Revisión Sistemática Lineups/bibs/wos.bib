}

@inproceedings{ WOS:001155004600027,
Author = {Xuan Thang Tran and Dai Tho Dang and Ngoc Thanh Nguyen},
Editor = {Nguyen, NT and Boonsang, S and Fujita, H and Hnatkowska, B and Hong, TP and Pasupa, K and Selamat, A},
Title = {Improving Hotel Customer Sentiment Prediction by Fusing Review Titles
   and Contents},
Booktitle = {INTELLIGENT INFORMATION AND DATABASE SYSTEMS, ACIIDS 2023, PT II},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2023},
Volume = {13996},
Pages = {323-335},
Note = {15th Asian Conference on Intelligent Information and Database Systems
   (ACIIDS), King Mongkuts Inst Technol Ladkrabang, Phuket, THAILAND, JUL
   24-26, 2023},
Organization = {Wroclaw Univ Sci \& Technol; IEEE SMC Tech Comm Computat Collect
   Intelligence; European Res Ctr Informat Syst; Univ Newcastle; Yeungnam
   Univ; Leiden Univ; Univ Teknologi Malaysia; BINUS Univ; Int Univ Vietnam
   Natl Univ; Nguyen Tat Thanh Univ},
Abstract = {The large volume of online customer reviews is a valuable source of
   information for potential customers when making decisions and for
   companies seeking to improve their products and services. While many
   researchers have focused on the content of reviews and their impact on
   customers' opinions using deep learning approaches, the mechanism by
   which review titles and contents influence sentiment analysis (SA) has
   received inadequate attention. This study proposes a deep learning-based
   fusion method that reveals the importance of reviewing titles and
   contents in predicting customer opinions. Our experiments on a crawled
   TripAdvisor dataset showed that the performance of the document-level SA
   task could be improved by 2.68\% to 12.36\% compared to baseline methods
   by effectively fusing informative review titles and contents.},
DOI = {10.1007/978-981-99-5837-5\_27},
