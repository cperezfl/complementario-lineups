@inproceedings{ WOS:000464097700131,
Author = {Singla, Zeenia and Randhawa, Sukhchandan and Jain, Sushma},
Book-Group-Author = {IEEE},
Title = {Sentiment Analysis of Customer Product Reviews Using Machine Learning},
Booktitle = {PROCEEDINGS OF 2017 INTERNATIONAL CONFERENCE ON INTELLIGENT COMPUTING
   AND CONTROL (I2C2)},
Year = {2017},
Note = {International Conference on Intelligent Computing and Control (I2C2),
   Anna Univ, Karpagam Coll Engn, Dept ETE, Coimbatore, INDIA, JUN 23-24,
   2017},
Organization = {IEEE Madras Sect; IEEE Robot \& Automat Soc},
Abstract = {Today, digital reviews play a pivotal role in enhancing global
   communications among consumers and influencing consumer buying patterns.
   E-commerce giants like Amazon, Flipkart, etc. provide a platform to
   consumers to share their experience and provide real insights about the
   performance of the product to future buyers. In order to extract
   valuable insights from a large set of reviews, classification of reviews
   into positive and negative sentiment is required. Sentiment Analysis is
   a computational study to extract subjective information from the text.
   In the proposed work, over 4,000,00 reviews have been classified into
   positive and negative sentiments using Sentiment Analysis. Out of the
   various classification models, Naive Bayes, Support Vector Machine (SVM)
   and Decision Tree have been employed for classification of reviews. The
   evaluation of models is done using 10 Fold Cross Validation.},
