	doi = {10.1007/978-981-95-5469-0_8},
	abstract = {The festivalImpact activities adopt strategies of professional leadership, empowerment learning, technological support, and partner communication to promote local culture and foster a harmonious society. The overarching purpose is to enhance social cohesionCohesion, strengthen the local economy, and implement incentive measures that provide leisure opportunities and spiritual sustenance for localLocal communities. This chapter uses the research and evaluation method to analyze the festival tourism scheme to explore the plan of festival tourism and the impact, and then the plan will provide a foundation for sustainable management of festival activities and provision of meaningful social feedback. It underlinesTourism the need for knowledgeKnowledge on core components of programProgram evaluationProgram evaluation and its use in festival tourism to be considered. FormativeFormative evaluation—which focuses on improving the festival program during the development process—is distinguished from summativeSummative evaluationSummative evaluation, which measures its results and its long-term impact after the implementation. The Program Logic Model (PLM)PLM (Program Logic Model) is introduced as central to festival planning and assessment. Based on this model, the chapter combines knowledgeKnowledge management, financial management and strategic management considerations to illustrate how festival activities support economic gains, communication gains and other quantitativeQuantitative measurements. On the other hand, the performance analysis of the ProgramProgram Logic Model also facilitates qualitativeQualitative analysis of wider impacts such as environmental, psychological, social, political and cultural effects. Furthermore, the chapter draws on theories and models such as the Expectancy-Disconfirmation TheoryExpectancy-disconfirmation theory (EDT) and Service Quality (SERVQUALSERVQUAL) in evaluating tourists’ satisfaction with services, thereby linking service qualityQuality and visitor experience with festival outcomes. It also categorizes the multifaceted impacts of festivals—economic, socio-cultural, and environmentalEnvironmental—to provide a comprehensive evaluation framework that supports both practical management and academic inquiry.},
	language = {en},
	urldate = {2026-05-05},
	booktitle = {Celebrating {Culture}: {Folk} {Tourism} {Through} {Festivals} and {Traditions}},
	publisher = {Springer Nature},
