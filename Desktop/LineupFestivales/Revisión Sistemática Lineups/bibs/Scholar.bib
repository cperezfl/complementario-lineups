}

@incollection{justice_festival_2015,
	address = {Dordrecht},
	title = {The {Festival} of {World} {Sacred} {Music}: {Creating} a {Destination} for {Tourism}, {Spirituality}, and the {Other}},
	isbn = {978-94-017-9376-6},
	shorttitle = {The {Festival} of {World} {Sacred} {Music}},
	url = {https://doi.org/10.1007/978-94-017-9376-6_148},
	doi = {10.1007/978-94-017-9376-6_148},
	abstract = {Festivals of world sacred music (WSM) carve out a unique space in the sacred landscape. They afford participants the chance to experience a variety of self-identities and spiritualties within the tolerantly ambiguous pluralism of a postmodern, post-touristic sacred geography. Festivals present a culture/religion for mass consumption. When we speak of featured acts as “presentations of” a culture or religion, this language reveals an awareness of the performative elements and acknowledges the intensification of cultural and spiritual awareness that occurs within this temporally and physically demarcated sphere. The geography of WSM poses questions of authenticity. How does the festival present itself? Do producers construe the costumes, attention to “authentic” performance details, and sense of communitas? Does the heightened attention in providing “authenticity” become a contrived display for outsiders? Categorizing an event as “overly religious and proselytizing,” “too pluralistic” or an “incoherent conglomeration of spirituality” says as much about the commentator’s preconceived frame as the content of the festival. The goals of religious festivals are in promoting arts, ethnic minorities, proselytizing, worship, and increasingly tourism. The element of sacred performance further complicates issues of authenticity. What are the implications when a large international festival, such as the Fes Festival, advertises itself as a forum for spiritual discovery? What is the impact of encouraging religious specificity along with spiritual pluralism? I use the Fes Festival to show how sacred music festivals create poignant points of entrée into an ecumenical spiritual experience. I analyze how festivals problematize ethnographic musical objects as created through processes of detachment and contextualization in which they situate music and cultures in a time out of time, in a space out of space. I close with a discussion how WSM festivals navigate a post-touristic geography of the world’s sacred landscapes and demonstrates how the created festival product offers a condensed form of experience that the average tourist would not likely encounter.},
	language = {en},
	urldate = {2026-05-05},
	booktitle = {The {Changing} {World} {Religion} {Map}: {Sacred} {Places}, {Identities}, {Practices} and {Politics}},
	publisher = {Springer Netherlands},
	author = {Justice, Deborah},
	editor = {Brunn, Stanley D.},
	year = {2015},
	keywords = {Festival, Performance, Religion, Sacred music, Tourism},
	pages = {2833--2849},
}

