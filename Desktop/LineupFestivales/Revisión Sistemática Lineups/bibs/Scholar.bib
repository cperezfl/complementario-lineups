@incollection{asif_prospects_2025,
	series = {Festival and {Event} {Tourism} and {Hospitality} {Series}},
	title = {Prospects and {Challenges} for {AI} and {Technological} {Innovation} in the {European} {Travel} and {Tourism} {Sector}: {Impact}, {Effect} and {Sustainable} {Development} {Goals}},
	isbn = {978-1-83699-016-1},
	shorttitle = {Prospects and {Challenges} for {AI} and {Technological} {Innovation} in the {European} {Travel} and {Tourism} {Sector}},
	url = {https://www.cabidigitallibrary.org/doi/abs/10.1079/9781836990185.0012},
	doi = {10.1079/9781836990185.0012},
	abstract = {Festival and event planning has improved participant experiences and accelerated sustainable development thanks to tourism technology and artificial intelligence (AI). Due to the 4.0 digital revolution, AI is transforming hospitality operations, demand forecasting, and customer pleasure. Virtual and augmented reality provide interactive tutorials and improve user experience. Mobile apps offer instant booking and updates. Tourism, sustainable development, and economic growth benefit from AI. This chapter examines how AI and technological innovation affect Europe’s sustainable development goals (SDGs), focusing on green solutions to lessen the industry’s environmental impact and raise awareness. However, labor shrinkage, skill gaps, ethics, cybersecurity, and economic implications exist. Festivals improve economic growth and social welfare by promoting cultural exchange and community. Events and tourism organizations satisfy client needs through social media and chatbot communication and customization. The chapter covers AI’s economic, social, and environmental downsides. It reviews research on hotels, event planners, and music festivals using technology and AI to encourage sustainable growth in Europe. A mixed-method study examines how European tourism has leveraged technology and AI for sustainable growth. AI helps festivals and events attract and engage participants, boosting operations, customer experiences, and sustainability. Tourism sustainability, customer satisfaction, and process efficiency are improved by AI. Addressing privacy, employment displacement, and ethics is essential to responsibly deploy AI. AI concerns privacy and data security issues, automation-related job losses, and ethical challenges about justice and trust. Tourism businesses must fund research and development (R\&D), work with technology providers, and involve stakeholders to integrate AI. Society must also advocate AI use responsibly. Companies should prioritize AI-based personalization, data protection, retraining, ethical AI, and stakeholder involvement. Future research should address AI’s economic and social effects.},
	urldate = {2026-05-05},
	booktitle = {Technological {Innovation} and {AI} for {Sustainable} {Development} in {Events} and {Festivals}},
	author = {Asif, Fizza and Jamshed, Kamran and Shah, Syed Haider Ali},
	month = may,
	year = {2025},
	pages = {140--161},
}

@article{de_lira_event_2019,
	title = {Event attendance classification in social media},
	volume = {56},
	issn = {0306-4573},
	url = {https://www.sciencedirect.com/science/article/pii/S0306457318303728},
	doi = {10.1016/j.ipm.2018.11.001},
	abstract = {Popular events are well reflected on social media, where people share their feelings and discuss their experiences. In this paper, we investigate the novel problem of exploiting the content of non-geotagged posts on social media to infer the users’ attendance of large events in three temporal periods: before, during and after an event. We detail the features used to train event attendance classifiers and report on experiments conducted on data from two large music festivals in the UK, namely the VFestival and Creamfields events. Our classifiers attain very high accuracy with the highest result observed for the Creamfields festival ( ∼ 91\% accuracy at classifying users that will participate in the event). We study the most informative features for the tasks addressed and the generalization of the learned models across different events. Finally, we discuss an illustrative application of the methodology in the field of transportation.},
	number = {3},
	urldate = {2026-05-05},
	journal = {Information Processing \& Management},
	author = {de Lira, Vinicius Monteiro and Macdonald, Craig and Ounis, Iadh and Perego, Raffaele and Renso, Chiara and Times, Valeria Cesario},
	month = may,
	year = {2019},
	keywords = {Classification, Event attendance prediction, Social media analysis},
	pages = {687--703},
	file = {ScienceDirect Full Text PDF:C\:\\Users\\cpere\\Zotero\\storage\\J37B6DSZ\\de Lira et al. - 2019 - Event attendance classification in social media.pdf:application/pdf;ScienceDirect Snapshot:C\:\\Users\\cpere\\Zotero\\storage\\KNQEJCHD\\S0306457318303728.html:text/html},
}

