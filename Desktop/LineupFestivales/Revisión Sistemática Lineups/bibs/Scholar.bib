@inproceedings{motupall_optimizing_2024,
	title = {Optimizing {Bike} {Rental} {Demand} {Forecasting} - {An} {Ensemble} {Machine} {Learning} {Approach}},
	url = {https://ieeexplore.ieee.org/abstract/document/10810973},
	doi = {10.1109/ICDICI62993.2024.10810973},
	abstract = {The growing popularity of bike-sharing programmes in metropolitan areas has increased the necessity for reliable demand forecast models to optimize fleet management and improve user experience. This study provides an ensemble modelling strategy combining decision trees, random forests, support vector machines (SVMs), and Bayesian inference to forecast bike rental demand accurately and robustly. The research begins by investigating the strengths of individual models, such as decision trees, random forests, SVMs, and Bayesian inference, in capturing diverse patterns and correlations in the bike rental dataset. Following that, an ensemble model is built by merging various algorithms, exploiting their complementary capabilities to overcome the constraints of individual models. Decision trees and random forests help capture intricate nonlinear relationships, whilst SVMs deal with high-dimensional feature spaces. Bayesian inference provides a probabilistic framework for quantifying uncertainty in predictions.The ensemble model is trained and validated on a large dataset that includes a variety of spatiotemporal characteristics, meteorological conditions, and historical usage trends. The model's performance is assessed through comparisons with traditional single-model approaches and an in-depth examination of ensemble model interpretability. The study also examines how hyperparameter tuning affects the ensemble's overall prediction accuracy and generalization capabilities. The interpretability of the model is illustrated by feature importance analysis, which highlights the major elements driving bike rental demand.},
	urldate = {2026-05-05},
	booktitle = {2024 5th {International} {Conference} on {Data} {Intelligence} and {Cognitive} {Informatics} ({ICDICI})},
	author = {Motupall, Ravikanth and Pavan, Beerla and Kanwal, Mutyapwar and Reddy, Devarapally Anvesh and Vignesh, Alladi and Burra, Lakshmi Ramani},
	month = nov,
	year = {2024},
	keywords = {Accuracy, Analytical models, Bayes methods, Bike Rental Demand, Correlation, Decision trees, Demand forecasting, Fleet Management, Hyperparameter Tuning, Model Interpretability, Predictive models, Random forests, Spatiotemporal characteristics, Urban areas, User experience},
	pages = {1419--1425},
	file = {Full Text PDF:C\:\\Users\\cpere\\Zotero\\storage\\EYH5RB8P\\Motupall et al. - 2024 - Optimizing Bike Rental Demand Forecasting - An Ensemble Machine Learning Approach.pdf:application/pdf},
