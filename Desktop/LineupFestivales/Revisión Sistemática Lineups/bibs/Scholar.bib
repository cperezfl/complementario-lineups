	volume = {4},
	doi = {10.46632/tfe/4/1/1},
	abstract = {Festivals are vibrant and meaningful events that bring people together to celebrate various forms of human expression. They blend music, art, food, and cultural traditions, creating opportunities for joy, entertainment, and shared experiences. These events take many forms, ranging from music festivals featuring diverse genres to cultural celebrations that preserve heritage, and art festivals that showcase creativity in the visual and performing arts. Sporting events also play a significant role, fostering both competition and collective enthusiasm. Meanwhile, food and beverage festivals offer a wide array of culinary experiences. From small local fairs to large-scale international gatherings, festivals strengthen social bonds and leave behind lasting memories. Research regarding festivals and events is crucial across cultural, economic, social, and organizational sectors. Studying festivals helps in preserving traditions and fostering understanding among different cultures. Economically, festivals boost tourism, create employment opportunities, and stimulate business growth, thereby proving valuable to policymakers and organizers alike. Socially, they enhance community cohesion by bringing people together. Festivals also serve as excellent platforms for marketing and branding, helping businesses improve their visibility and engagement. Additionally, they encourage artistic innovation and assist researchers in understanding audience preferences. The VIKOR method, utilized in multi-criteria decision-making, evaluates and ranks alternative options based on specific criteria. When applied to festival analysis, this compares aspects such as attendance, economic impact, satisfaction, and media coverage. The results indicate that arts and film festivals rank the highest, while sporting events receive the lowest rankings.},
	journal = {Trends in Finance and Economics},
	author = {Selvam, Manjula},
	month = mar,
	year = {2026},
	pages = {1},
	file = {Full Text PDF:C\:\\Users\\cpere\\Zotero\\storage\\QULABWVF\\Selvam - 2026 - The Role of Festivals and Events in The Regional Development using the VIKOR Method.pdf:application/pdf},
}

@article{green_splendour_2025,
	title = {Splendour {XR}: {Place}, {Experience} and {Liveness} at a {Virtual} {Music} {Festival}},
